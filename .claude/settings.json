{
  "enabledPlugins": {
    "notebooklm@notebooklm-plugin": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(notebooklm *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/notebooklm-ptbr-rule.sh",
            "timeout": 5,
            "statusMessage": "Applying pt-BR rule for NotebookLM..."
          }
        ]
      }
    ]
  }
}
