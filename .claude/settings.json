{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/notebooklm-ptbr-rule.sh",
            "if": "Bash(notebooklm *)",
            "timeout": 5,
            "statusMessage": "Applying pt-BR rule for NotebookLM..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/community-forum-apify-rule.sh",
            "timeout": 5,
            "statusMessage": "Checking community-forum → Apify rule..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {}
}
